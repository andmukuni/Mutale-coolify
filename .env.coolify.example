# Coolify staging environment template
# Copy these into Coolify UI → Environment Variables (never commit real secrets)
# Full guide: DEPLOY_COOLIFY.md

NODE_ENV=production
PORT=4000

# ── Database (Coolify-managed MySQL — use INTERNAL hostname) ─────────────────
# Get these from Coolify → MySQL resource → Connection details (internal)
DB_HOST=
DB_PORT=3306
DB_USER=mysql
DB_PASSWORD=
DB_NAME=default

# ── Public URL (set AFTER first deploy — use Coolify auto-generated URL) ─────
# Must match exactly what you open in the browser (no trailing slash)
APP_URL=https://your-coolify-generated-url.example.com
CORS_ORIGINS=https://your-coolify-generated-url.example.com
TRUST_PROXY=1

# ── Security (generate new values — do not reuse cPanel production) ─────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN_SECRET=
ADMIN_API_KEY=

# Required on first deploy (NODE_ENV=production) — used only if no admin exists yet
DEFAULT_ADMIN_EMAIL=admin@staging.mutalemubanga.org
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NAME=Mutale Mubanga

# ── Receipt PDF (jsPDF — no Chromium in container) ──────────────────────────
RECEIPT_PDF_LEGACY=1

# ── Payments (optional — Lenco sandbox for staging) ─────────────────────────
PAYMENT_PROVIDER=lenco
PAYMENT_CURRENCY=ZMW
LENCO_SANDBOX=true
LENCO_PUBLIC_KEY=
LENCO_SECRET_KEY=
LENCO_WEBHOOK_SECRET=
LENCO_ACCOUNT_ID=

# ── NRC verification (optional — or configure in Admin → Settings → NRC Verification) ─
# SMARTDATA_API_KEY=
# SMARTDATA_BASE_URL=https://mysmartdata.tech/api/v1
# NRC_VERIFICATION_ENABLED=true
