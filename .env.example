# XAMPP MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mutale

# API server
PORT=4000

# Payment gateway defaults (Lenco)
PAYMENT_PROVIDER=lenco
PAYMENT_CURRENCY=ZMW
LENCO_PUBLIC_KEY=
LENCO_SECRET_KEY=
LENCO_WEBHOOK_SECRET=
LENCO_ACCOUNT_ID=
LENCO_SANDBOX=true

# Security hardening (required in production)
# Comma-separated list, e.g. http://localhost:5173,https://yourdomain.com
# In production, unset CORS_ORIGINS blocks cross-origin API access (fail-closed).
CORS_ORIGINS=http://localhost:5173

# Public app URL (used for same-origin CORS and email links)
APP_URL=http://localhost:5173

# Behind nginx/cPanel reverse proxy — enables correct client IP for rate limits
TRUST_PROXY=1

# If set, sensitive admin API endpoints require either:
# - Header: x-admin-api-key: <value>
# - or Authorization: Bearer <value>
ADMIN_API_KEY=

# HMAC secret used to sign user auth tokens for protected profile updates
# Use a long random string in production.
AUTH_TOKEN_SECRET=

# Zoom (virtual events — optional if configured in Admin → Video Meetings)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_DEFAULT_HOST_EMAIL=
ZOOM_MEETING_SDK_KEY=
ZOOM_MEETING_SDK_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# Daily.co (virtual events — optional if configured in Admin → Video Meetings)
DAILY_API_KEY=
DAILY_DOMAIN=
DAILY_WEBHOOK_SECRET=

# Receipt PDF generation (cPanel / shared hosting)
# Production defaults to jsPDF (RECEIPT_PDF_LEGACY behaviour) — Puppeteer/Chromium is unreliable on cPanel.
# Set RECEIPT_PDF_LEGACY=1 explicitly to force jsPDF on any environment.
# Set RECEIPT_PDF_HTML=1 on production only if you have VPS/dedicated hosting with Chromium support.
RECEIPT_PDF_LEGACY=
RECEIPT_PDF_HTML=
