# Dependencies & build output (rebuilt inside the image)
node_modules
dist
mutale2

# Local env & secrets — inject via Coolify env vars instead
.env
.env.*
!.env.example

# VCS / editor / OS
.git
.gitignore
.DS_Store
*.code-workspace
.vscode
.idea

# Logs
*.log
stderr*.log

# Local uploads — served from a runtime volume, not baked into the image
uploads

# Packaging artifacts / archives
Zip
*.zip
mutale-cpanel-*.zip

# cPanel/Passenger-specific deploy tooling (not used on Coolify)
.htaccess
app.js
lsentry.cjs
deploy.sh
DEPLOY_CPANEL.md

# Tests & docs not needed at build time
**/__tests__
*.test.js
EVENTS_BUGFIX_PLAN.md
zoom_sdk_event_system_implementation_guide.md

# Unused root-level image (the Mutale logo PNGs ARE needed by the vite build via
# src/utils/certificateImage.js, so we cannot exclude root-level PNGs)
# Keeping large logo files in the image is acceptable (~100 KB total).
