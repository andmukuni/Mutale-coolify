{
  "name": "mutale",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:daily": "node server/scripts/test-daily-integration.js",
    "test:receipt-pdf": "node scripts/test-receipt-pdf.mjs",
    "test:watch": "vitest",
    "server:dev": "node --watch server/index.js",
    "server:start": "node server/index.js",
    "server:seed": "node server/seed.js",
    "seed:demo-cert": "node server/scripts/seed-demo-certificate.js",
    "seed:admin-cv-profile": "node server/scripts/seed-admin-cv-profile.js",
    "seed:rbac": "node server/scripts/seed-rbac.js",
    "seed:partner-logos": "node server/scripts/seed-partner-logos.js",
    "start": "NODE_ENV=production node server/index.js",
    "deploy:build": "npm run build && echo 'Build complete — upload dist/, server/, package.json, .env to cPanel'",
    "deploy:zip": "bash scripts/make-cpanel-update-zip.sh",
    "deploy:coolify:verify": "bash scripts/verify-coolify-deploy.sh",
    "deploy:coolify:seed": "bash scripts/coolify-seed.sh",
    "deploy:coolify:preflight": "node scripts/coolify-preflight.mjs",
    "deploy:coolify:check": "bash scripts/coolify-compose-check.sh",
    "deploy:coolify:postdeploy": "bash scripts/coolify-postdeploy.sh",
    "fix-deployment": "bash scripts/fix-deployment.sh",
    "install:production": "npm install --omit=dev --legacy-peer-deps"
  },
  "dependencies": {
    "@daily-co/daily-js": "^0.83.1",
    "@tiptap/extension-color": "^3.24.0",
    "@tiptap/extension-font-family": "^3.24.0",
    "@tiptap/extension-highlight": "^3.24.0",
    "@tiptap/extension-image": "^3.24.0",
    "@tiptap/extension-link": "^3.24.0",
    "@tiptap/extension-placeholder": "^3.24.0",
    "@tiptap/extension-text-align": "^3.24.0",
    "@tiptap/extension-text-style": "^3.24.0",
    "@tiptap/extension-underline": "^3.24.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "@zoom/meetingsdk": "^6.0.0",
    "canvas": "^3.2.3",
    "cors": "^2.8.6",
    "docx": "^9.7.1",
    "dompurify": "^3.4.7",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsdom": "^29.1.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "mysql2": "^3.22.0",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "optionalDependencies": {
    "puppeteer": "^24.43.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
